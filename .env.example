# Required in production. Set in Vercel → Project → Settings → Environment Variables.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_KEY=

# Supabase — Dashboard → Project Settings → Data API for the URL,
# and Project Settings → API → service_role (NOT anon) for the key.
# The service role key bypasses RLS; keep it server-only, never expose to the client.
# For local dev, leave them blank and the app falls back to an in-memory store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
