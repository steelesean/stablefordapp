# Required in production. Set in Vercel → Project → Settings → Environment Variables.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_KEY=

# Auto-injected by the Vercel Upstash Redis integration. You do NOT set these manually in prod.
# For local dev, leave them blank and the app falls back to an in-memory store.
KV_REST_API_URL=
KV_REST_API_TOKEN=
