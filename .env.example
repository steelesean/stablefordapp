# Required in production (legacy single-round mode).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_KEY=

# Supabase — Dashboard → Project Settings → Data API for the URL,
# and Project Settings → API → service_role (NOT anon) for the key.
# The service role key bypasses RLS; keep it server-only, never expose to the client.
# For local dev, leave them blank and the app falls back to an in-memory store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase public keys — safe to expose to the browser.
# Used for organizer auth (login/signup) via @supabase/ssr.
# URL is the same value as SUPABASE_URL above.
# Anon key is from Supabase → Project Settings → API → anon (NOT service_role).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
